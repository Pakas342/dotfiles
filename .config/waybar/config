{
    // -------------------------------------------------------------------------
    // Global configuration
    // -------------------------------------------------------------------------

    "layer": "top",

    "position": "top",

    // If height property would be not present, it'd be calculated dynamically
    "height": 30,

    "modules-left": [
        "hyprland/workspaces"
    ],

    "modules-right": [
        "network",
	"battery",
        "memory",
        "cpu",
        "clock#date",
        "clock#time"
    ],


    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

    "clock#time": {
        "interval": 1,
        "format": "ΎΑΩ  {:%H:%M}",
        "tooltip": false
    },

    "clock#date": {
      "interval": 10,
      "format": "ΎΒ│  {:%e %b %Y}", // Icon: calendar-alt
      "tooltip-format": "{:%e %B %Y}"
    },

    "cpu": {
        "interval": 5,
        "format": "ΎΜδ  {usage}% ({load})", // Icon: microchip
        "states": {
          "warning": 70,
          "critical": 90
        }
    },

    "memory": {
        "interval": 5,
        "format": "Ό┐Ζ  {}%", // Icon: memory
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "interval": 5,
        "format-wifi": "ΎΘτ  {signalStrength}%", // Icon: wifi
        "format-ethernet": "ΎηΨ  {ifname}: {ipaddr}/{cidr}", // Icon: ethernet
        "format-disconnected": "έγι  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}"
    },

    "hyprland/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{icon} {name}",
        "format-icons": {
            "1": "ΎΤΚ",
            "2": "≤░Θπ",
            "3": "≤░ΤΜ",
            "4": "ΎΛ╢",
            "5": "≤░Γ║",
            "6": "Ό░δ",
	    "8": "≤░Γ║",
	    "10": "Ό░Ω",
            "default": "ΎΕΣ"
        }
    },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ  {capacity}%",
    "format-plugged": "≤░ΓΕ  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-full": "≤▒ΙΣ  {capacity}%",
    "format-icons": [
      "≤▒Λκ",
      "≤▒Λλ",
      "≤▒Λμ"
    ]
  },

